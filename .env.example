# Copy this file to .env and fill in real values. NEVER put secrets in this tracked file.
#   cp .env.example .env

# --- Neo4j (Aura) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=
AURA_INSTANCENAME=

# --- Apify ---
APIFY_TOKEN=
# after you deploy the luma-scraper actor, put its id here (e.g. yourname~luma-scraper)
LUMA_ACTOR_ID=
# a finished run's default dataset id, for `npm run ingest:apify`
LUMA_DATASET_ID=

# --- Butterbase (wire in Phase 5) ---
BUTTERBASE_URL=
BUTTERBASE_KEY=

# --- RocketRide Cloud (fill after deploy in Phase 4) ---
ROCKETRIDE_ENDPOINT=

# --- Luma session cookie (full Cookie header string from a logged-in session) ---
LUMA_COOKIE=
